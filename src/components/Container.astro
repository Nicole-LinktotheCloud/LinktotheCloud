---
/* Container — centers content horizontally with max-width and consistent padding.
   variant="prose" caps at 720px; variant="wide" caps at 1080px. */

interface Props {
  variant?: 'prose' | 'wide';
  class?: string;
}

const { variant = 'wide', class: className } = Astro.props;
---

<div class:list={['container', `container--${variant}`, className]}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  .container--prose { max-width: var(--max-width-prose); }
  .container--wide  { max-width: var(--max-width-wide); }

  @media (min-width: 768px) {
    .container { padding-inline: var(--space-8); }
  }
</style>
