---
/* Prose — styles Markdown-rendered content for blog posts and case studies.
   Wrap <Content /> from a content collection entry with this component. */

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['prose', className]}>
  <slot />
</div>

<style>
  .prose {
    max-width: var(--max-width-prose);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .prose :global(h1) { font-size: var(--text-3xl); }
  .prose :global(h2) { font-size: var(--text-2xl); }
  .prose :global(h3) { font-size: var(--text-xl); }
  .prose :global(h4) { font-size: var(--text-lg); }

  .prose :global(p) { margin-bottom: var(--space-6); }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-8);
    margin-bottom: var(--space-6);
  }

  .prose :global(li) { margin-bottom: var(--space-2); }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) { color: var(--color-accent-hover); }

  /* Inline code */
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 1px 5px;
  }

  /* Code blocks */
  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--space-6);
    overflow-x: auto;
    margin-bottom: var(--space-6);
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-6);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0 0 var(--space-6);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-12) 0;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: var(--border-radius);
    border: 1px solid var(--color-border);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(th) {
    font-family: var(--font-mono);
    font-weight: 600;
  }
</style>
