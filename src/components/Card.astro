---
/* Card — project case study card with title, summary, tags, and optional link.
   Used in a grid on the Projects page. */

import Tag from './Tag.astro';

interface Props {
  title: string;
  summary: string;
  tags?: string[];
  href?: string;
}

const { title, summary, tags = [], href } = Astro.props;
---

<article class="card">
  <div class="card-body">
    <h3 class="card-title">
      {href ? <a href={href}>{title}</a> : title}
    </h3>
    <p class="card-summary">{summary}</p>
    {tags.length > 0 && (
      <ul class="card-tags" aria-label="Technologies used">
        {tags.map(tag => (
          <li><Tag label={tag} /></li>
        ))}
      </ul>
    )}
  </div>
</article>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--space-8);
    transition: border-color 0.15s;
  }

  .card:hover { border-color: var(--color-accent); }

  .card-title {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
  }

  .card-title a:hover { color: var(--color-accent); }

  .card-summary {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-4);
  }

  .card-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
