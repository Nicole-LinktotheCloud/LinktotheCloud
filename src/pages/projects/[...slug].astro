---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import Prose from '../../components/Prose.astro';
import Tag from '../../components/Tag.astro';
import Button from '../../components/Button.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} — Nicole Inman`}
  description={entry.data.description}
>
  <Section>
    <Container variant="prose">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/projects">Projects</a>
        <span aria-hidden="true"> / </span>
        <span>{entry.data.title}</span>
      </nav>

      <header class="project-header">
        <h1 class="project-title">{entry.data.title}</h1>

        {entry.data.role && (
          <p class="project-role">{entry.data.role}</p>
        )}

        {entry.data.stack && entry.data.stack.length > 0 && (
          <ul class="project-stack" aria-label="Stack">
            {entry.data.stack.map(item => (
              <li><Tag label={item} /></li>
            ))}
          </ul>
        )}
      </header>

      <Prose>
        <Content />
      </Prose>

      <div class="project-footer">
        <Button href="/projects" variant="secondary">← All Projects</Button>
        <Button href="/contact">Get in Touch</Button>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--color-accent); }

  .project-header { margin-bottom: var(--space-12); }

  .project-title {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 700;
    margin: 0 0 var(--space-4);
    line-height: var(--leading-tight);
  }

  .project-role {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .project-stack {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .project-footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }
</style>
