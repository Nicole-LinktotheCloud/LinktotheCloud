---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Nicole Inman — AI Automation & Cloud Architecture"
  description="AI automation specialist and cloud automation architect. Building governed, connected workflows that reduce manual work and improve data accuracy."
>
  <Section>
    <Container variant="prose">
      <div class="hero">
        <p class="hero-label">AI automation &middot; cloud architecture &middot; fullstack</p>
        <h1 class="hero-headline">
          AI-powered automation.<br />Architected, not assembled.
        </h1>
        <p class="hero-sub">
          Building governed, repeatable automation systems for business operations —
          from intelligent document processing to autonomous agent pipelines.
        </p>
        <div class="hero-actions">
          <Button href="/projects">View Projects</Button>
          <Button href="/about" variant="secondary">About</Button>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>

<style>
  .hero { padding-block: var(--space-24); }

  .hero-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
  }

  .hero-headline {
    font-family: var(--font-mono);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-6);
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 560px;
    margin: 0 0 var(--space-8);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>
