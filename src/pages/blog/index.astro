---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Container from '../../components/Container.astro';
import Tag from '../../components/Tag.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Blog — Nicole Inman"
  description="Writing on AI automation, open-source infrastructure, Power Platform, and building automation systems that last."
>
  <Section>
    <Container variant="prose">
      <h1 class="page-heading">Blog</h1>
      <p class="page-sub">
        AI, automation, and the practical business of building systems that stay running.
      </p>

      {posts.length === 0 ? (
        <p class="empty">No posts yet.</p>
      ) : (
        <ul class="post-list" aria-label="Blog posts">
          {posts.map(post => (
            <li class="post-item">
              <a href={`/blog/${post.id}`} class="post-link">
                <article>
                  <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                  <h2 class="post-title">{post.data.title}</h2>
                  <p class="post-description">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <ul class="post-tags" aria-label="Tags">
                      {post.data.tags.map(tag => (
                        <li><Tag label={tag} /></li>
                      ))}
                    </ul>
                  )}
                </article>
              </a>
            </li>
          ))}
        </ul>
      )}
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-heading {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 700;
    margin: 0 0 var(--space-4);
  }

  .page-sub {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-12);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child { border-top: 1px solid var(--color-border); }

  .post-link {
    display: block;
    padding: var(--space-8) 0;
    text-decoration: none;
    color: inherit;
  }

  .post-link:hover .post-title { color: var(--color-accent); }

  .post-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .post-title {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
    transition: color 0.15s;
    line-height: var(--leading-tight);
  }

  .post-description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-4);
  }

  .post-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
