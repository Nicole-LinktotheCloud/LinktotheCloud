---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
---

<BaseLayout
  title="Contact — Nicole Inman"
  description="Get in touch about automation architecture, AI systems, Power Platform consulting, or open-source automation work."
>
  <Section>
    <Container variant="prose">
      <h1 class="page-heading">Let's talk about your operations</h1>
      <p class="lead">
        If you have manual processes eating time, fragmented systems that should be connected,
        or automation that needs an architect rather than another consultant who'll hand you
        a flow and leave — reach out.
      </p>
      <p>
        Based in Renton, WA. Available for remote engagements worldwide.
      </p>

      <ul class="contact-list" aria-label="Contact methods">
        <li class="contact-item">
          <span class="contact-label">Email</span>
          <a href="mailto:nicole@linktothecloud.com" class="contact-link">
            nicole@linktothecloud.com
          </a>
        </li>
        <li class="contact-item">
          <span class="contact-label">Upwork</span>
          <!-- Update with verified Upwork profile URL -->
          <a
            href="https://www.upwork.com/freelancers/nicoleinman"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
          >
            upwork.com/freelancers/nicoleinman
          </a>
        </li>
        <li class="contact-item">
          <span class="contact-label">LinkedIn</span>
          <!-- Update with verified LinkedIn profile URL -->
          <a
            href="https://www.linkedin.com/in/nicole-inman"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
          >
            linkedin.com/in/nicole-inman
          </a>
        </li>
        <li class="contact-item">
          <span class="contact-label">GitHub</span>
          <a
            href="https://github.com/Nicole-LinktotheCloud"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
          >
            github.com/Nicole-LinktotheCloud
          </a>
        </li>
      </ul>
    </Container>
  </Section>
</BaseLayout>

<style>
  .page-heading {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-8);
  }

  .lead {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-6);
  }

  p {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-12);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .contact-item {
    display: grid;
    grid-template-columns: 6rem 1fr;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-item:first-child { border-top: 1px solid var(--color-border); }

  .contact-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .contact-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .contact-link:hover { color: var(--color-accent); }
</style>
